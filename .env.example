# PureLink 自部署配置示例。
# 使用前复制为 .env：
#   cp .env.example .env
#
# 默认配置可以跑通本地 Docker 文本 demo，不需要任何外部 API key。
# 如需更好的问答和检索效果，再切换到外部 LLM / Embedding Provider。

# ---------------------------------------------------------------------------
# 应用与认证
# ---------------------------------------------------------------------------
APP_NAME=PureLink
APP_ENV=development
APP_DEBUG=false
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# 本地开发密钥。对外部署前必须替换为更安全的随机值，不要提交真实密钥。
AUTH_SECRET_KEY=purelink-dev-secret-key-change-me
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# 访问地址与 CORS
# ---------------------------------------------------------------------------
# 浏览器访问 API 的基础地址。Next.js Docker 镜像会在构建时写入 NEXT_PUBLIC_API_BASE_URL。
API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# 浏览器访问前端的地址，make check 会用它检查前端是否可访问。
FRONTEND_BASE_URL=http://localhost:3000

# 允许访问 API 的前端来源，多个值用英文逗号分隔。
# 云服务器部署时，把 localhost 替换成你的真实前端域名。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false

# ---------------------------------------------------------------------------
# 数据库与 Redis
# ---------------------------------------------------------------------------
# 这两个 URL 主要用于非 Docker 手动运行。
# Docker Compose 会给 api / worker 注入容器内部的 db / redis 地址。
DATABASE_URL=postgresql+psycopg://purelink:purelink@localhost:5432/purelink
REDIS_URL=redis://localhost:6379/0
DB_ECHO=false

# Docker Compose 数据库与端口配置。
POSTGRES_DB=purelink
POSTGRES_USER=purelink
POSTGRES_PASSWORD=purelink
POSTGRES_PORT=5432
REDIS_PORT=6379
APP_PORT=8000
FRONTEND_PORT=3000

# ---------------------------------------------------------------------------
# 本地文件存储
# ---------------------------------------------------------------------------
# 默认使用仓库内 data/ 目录，并挂载到 Docker api / worker 容器。
DATA_DIR=data
UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
CHUNKS_DIR=data/chunks
VECTOR_STORE_DIR=data/vector_store

# 兼容旧版本和 legacy worker-go。新配置优先使用 CHUNKS_DIR。
CHUNK_DIR=data/chunks

# Chunking strategy.
# fixed preserves the established flat-text chunking behavior.
# block_aware uses persisted DocumentBlock structure to keep headings/tables/code closer to source boundaries.
CHUNK_STRATEGY=fixed
BLOCK_CHUNK_TARGET_CHARS=900
BLOCK_CHUNK_MAX_CHARS=1400
BLOCK_CHUNK_MIN_CHARS=120
BLOCK_CHUNK_TABLE_MAX_CHARS=1800
BLOCK_CHUNK_OVERLAP_CHARS=120

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
# 用于问答生成。
# 默认 heuristic 不需要 API key，适合本地 demo，但不是最佳回答质量。
# 如需更高质量回答，可切换为 openai_compatible 或 deepseek 并填写 API 地址、Key 和模型名。
LLM_PROVIDER=heuristic
LLM_API_BASE_URL=
LLM_API_KEY=
# DeepSeek 兼容别名。若已填写 LLM_API_KEY，可留空。
DEEPSEEK_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=30
# DeepSeek 等 reasoning 模型可选：
# LLM_PROVIDER=deepseek
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-pro
# LLM_REASONING_EFFORT=high
# LLM_THINKING_ENABLED=true
LLM_REASONING_EFFORT=
LLM_THINKING_ENABLED=false

# ---------------------------------------------------------------------------
# Embedding Provider
# ---------------------------------------------------------------------------
# 用于文档索引和语义检索。
# 默认 fastembed + BAAI/bge-small-zh-v1.5，可在本地提供真实语义 embedding。
# 首次运行会下载模型到 EMBEDDING_MODEL_CACHE_DIR。
# 如果不想下载任何 embedding 模型，可切换为 local_hashed_bow。
# sentence_transformers 属于高级可选方案，需要额外安装 requirements-embedding-torch.txt。
# 切换 EMBEDDING_PROVIDER 或 EMBEDDING_MODEL 后，已有 indexed 文档建议重新索引。
EMBEDDING_PROVIDER=fastembed
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# 仅 sentence_transformers provider 使用该配置；fastembed 默认忽略。
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
EMBEDDING_MODEL_CACHE_DIR=/app/models/embedding
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSION=

# ---------------------------------------------------------------------------
# OCR Provider
# ---------------------------------------------------------------------------
# Core 版本默认关闭 OCR，不处理图片和扫描版 PDF。
# 如需后续扩展，可显式开启 ENABLE_OCR 并接入可选 OCR 依赖。
ENABLE_OCR=false
OCR_PROVIDER=disabled
OCR_LANG=eng
OCR_TESSERACT_COMMAND=tesseract
OCR_TESSERACT_PSM=6

# ---------------------------------------------------------------------------
# ASR Provider
# ---------------------------------------------------------------------------
# Core 版本默认关闭媒体处理，不处理音频和视频文件。
# 如需后续扩展，可显式开启 ENABLE_MEDIA 并接入可选 ASR 依赖。
ENABLE_MEDIA=false
ASR_PROVIDER=disabled
ASR_MODEL_PATH=/app/models/vosk
ASR_FFMPEG_COMMAND=ffmpeg

# 保留未来多模态扩展占位，Core 默认关闭。
MULTIMODAL_PROVIDER=disabled

# ---------------------------------------------------------------------------
# Reranker Provider
# ---------------------------------------------------------------------------
# Optional reranker. Keep disabled for lightweight local deployment.
RERANKER_ENABLED=false
RERANKER_PROVIDER=noop
RERANKER_MODEL=

# For lightweight deterministic testing:
# RERANKER_ENABLED=true
# RERANKER_PROVIDER=local_rule_reranker
# RERANKER_MODEL=local_rule_reranker

# For enhanced local reranking, requires optional FlagEmbedding dependency:
# RERANKER_ENABLED=true
# RERANKER_PROVIDER=flagembedding
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3

RERANKER_TOP_N=50
FINAL_CONTEXT_TOP_K=8
# ask 阶段最低来源分数阈值。低于该阈值时，PureLink 会返回“没有足够可靠依据”。
RETRIEVAL_MIN_SCORE=0.15
KEYWORD_RETRIEVAL_TOP_N=50
KEYWORD_RETRIEVAL_MIN_SCORE=0.05
# overview 问题会按 indexed 文档均衡采样代表性 chunks，而不是只用普通 semantic top-k。
OVERVIEW_MAX_CHUNKS=10
OVERVIEW_MAX_CHUNKS_PER_DOCUMENT=2
# 连续追问时，会读取最近几条会话消息辅助理解“它 / 这个 / 上面说的”等指代关系。
CONVERSATION_RECENT_MESSAGES_LIMIT=8
CONVERSATION_CONTEXT_MAX_CHARS=3000
CONVERSATION_MESSAGE_MAX_CHARS=800
# citation snippet 会在 retrieval chunk 之上进一步切成更短的句子级片段。
CITATION_UNIT_MIN_CHARS=40
CITATION_UNIT_TARGET_CHARS=120
CITATION_UNIT_MAX_CHARS=300
CITATION_UNIT_MAX_SENTENCES=3
MAX_CITATIONS=6

# ---------------------------------------------------------------------------
# 后台处理队列
# ---------------------------------------------------------------------------
PROCESSING_QUEUE_KEY=purelink:processing-jobs:queued
PROCESSING_INFLIGHT_QUEUE_KEY=purelink:processing-jobs:inflight
PROCESSING_QUEUE_BLOCK_TIMEOUT_SECONDS=5
# worker 会周期性把数据库中仍处于 queued 的 job 重新投递到 Redis，避免消息丢失后长期卡住。
PROCESSING_QUEUE_RECOVERY_INTERVAL_SECONDS=30
# 单个后台任务超过该秒数仍未完成时，会被判定为超时失败。
PROCESSING_JOB_TIMEOUT_SECONDS=1800
# 上传入口限制：后端会强制校验，不只依赖前端。
MAX_UPLOAD_SIZE_MB=50
MAX_ACTIVE_JOBS_PER_USER=5
MAX_ACTIVE_JOBS_PER_KB=10
WORKER_POLL_INTERVAL=5s

# ---------------------------------------------------------------------------
# 兼容说明
# ---------------------------------------------------------------------------
# 旧变量名仍会被代码兼容读取，但新部署建议优先使用上方名称：
# - CORS_ALLOW_ORIGINS -> CORS_ORIGINS
# - CHUNK_DIR -> CHUNKS_DIR
# - LLM_API_BASE -> LLM_API_BASE_URL
# - EMBEDDING_API_BASE -> EMBEDDING_API_BASE_URL
# - OCR_LANGUAGE -> OCR_LANG
# - ASR_VOSK_MODEL_PATH -> ASR_MODEL_PATH
